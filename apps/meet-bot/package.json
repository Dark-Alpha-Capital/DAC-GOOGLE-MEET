{
  "name": "meet-bot",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot index.ts",
    "build": "bun build ./index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "docker:build": "docker build -t meet-bot .",
    "docker:run": "docker run --rm -p 8080:8080 meet-bot"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "puppeteer-core": "^25.3.0"
  }
}
