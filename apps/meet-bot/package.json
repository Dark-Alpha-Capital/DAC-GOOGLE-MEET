{
  "name": "meet-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "docker:build": "docker build -t meet-bot .",
    "docker:run": "docker run --rm -p 8080:8080 meet-bot"
  },
  "dependencies": {
    "puppeteer-core": "^24.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
